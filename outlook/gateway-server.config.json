{
  "port": 8385,
  "host": "127.0.0.1",
  "cors": false,
  "auth": {
    "type": "none"
  },
  "gateway": {
    "methods": {
      "visibility": [
        {
          "identity": {
            "application": "Outlook"
          },
          "restrictions": "cluster"
        },
        {"restrictions":  "local"}
      ]
    },
    "peers": {
      "visibility": [
        {
          "domain": "agm",
          "restrictions": "cluster"
        }
      ]
    },
    "mesh": {
      "auth": {
        "user": null
      },
      "cluster": {
        "endpoint": "http://localhost:8084"
      },
      "enabled": true
    }
  }
}
